# ─────────────────────────────────────────────────────────────
# HH Jewelry — environment variables
# Copy this file to ".env.local" (local) or set these in Vercel.
# ─────────────────────────────────────────────────────────────

# ── Google Sheet backend (orders) ──
# The deployed Apps Script web app URL (ends in /exec) and a shared
# secret that must EXACTLY match the SECRET in google-apps-script/Code.gs
SHEET_WEBAPP_URL="https://script.google.com/macros/s/XXXXXXXX/exec"
SHEET_SECRET="CHANGE_ME_TO_A_LONG_RANDOM_STRING"

# ── Admin login (protects /admin) ──
ADMIN_USER="admin"
ADMIN_PASSWORD="change-this-password"

# ── Email notifications (optional — uses Resend) ──
# Sign up free at https://resend.com, create an API key.
RESEND_API_KEY=""
OWNER_EMAIL="you@example.com"
# Optional verified sender; defaults to Resend's test sender if blank:
EMAIL_FROM="HH Jewelry <onboarding@resend.dev>"

# ── WhatsApp notifications (optional — uses CallMeBot, free) ──
# Setup: https://www.callmebot.com/blog/free-api-whatsapp-messages/
WHATSAPP_PHONE="212600000000"
CALLMEBOT_APIKEY=""
